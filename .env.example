# -------- App (Flutter) --------
# Web Push (FCM)
FCM_VAPID_KEY=

# Stripe (PUBLICГѓВЃVEL)
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Google Places (Autocomplete/Geocoding)
GOOGLE_PLACES_API_KEY=

# Google Maps (SDKs / Web)
GOOGLE_MAPS_API_KEY=

# Ativar emuladores Firebase no DEV
USE_FIREBASE_EMULATORS=true
FIREBASE_EMULATOR_HOST=localhost
# RegiГѓВЈo das Functions (alinha com Firebase Functions)
FIREBASE_FUNCTIONS_REGION=europe-west1

# ForГѓВ§ar Semantics no Web (ГѓВєtil para Playwright)
FORCE_WEB_SEMANTICS=true

# ComissГѓВЈo da plataforma (fallback se Remote Config nГѓВЈo estiver configurado)
DEFAULT_COMMISSION_RATE=0.15

# URL base do teu domГѓВ­nio (para App Links / Universal Links)
APP_BASE_URL=https://app.chegaja.exemplo
