rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // Helpers
    // -------------------------
    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    // Admin claim SAFE: se nÃ£o existir, devolve false
    function isAdmin() {
      return signedIn()
        && request.auth.token != null
        && request.auth.token.keys().hasAny(['admin'])
        && request.auth.token['admin'] == true;
    }

    // DEV MODE (manual):
    // - deixa true enquanto estÃ¡s a desenvolver / emuladores
    // - muda para false antes de fazer deploy para produÃ§Ã£o
    function devMode() { return false; }

    function isSelf(userId) { return signedIn() && uid() == userId; }
    function clienteIdFromData(data) {
      return data is map
        ? (data.keys().hasAny(['clienteId'])
          ? data['clienteId']
          : (data.keys().hasAny(['clientId']) ? data['clientId'] : null))
        : null;
    }


    // -------------------------
    // Pedido helpers
    // -------------------------
    function pedidoSnap(pedidoId) {
      return get(/databases/$(database)/documents/pedidos/$(pedidoId));
    }

    // âœ… Quando estamos fora do match /pedidos, precisamos ler o pedido por ID.
    function isPedidoParticipantById(pedidoId) {
      let p = pedidoSnap(pedidoId).data;
      return signedIn() && p is map
        ? (
          clienteIdFromData(p) == uid() ||
          (p.keys().hasAny(['prestadorId']) && p['prestadorId'] == uid())
        )
        : false;
    }

    // âœ… Quando jÃ¡ temos o doc (resource.data), NÃƒO uses get()
    function isPedidoParticipantByData(data) {
      return signedIn()
        && data is map
        && (
          clienteIdFromData(data) == uid() ||
          (data.keys().hasAny(['prestadorId']) &&
            data['prestadorId'] == uid())
        );
    }

    function isPrestador() {
      return signedIn()
        && exists(/databases/$(database)/documents/prestadores/$(uid()));
    }

    // -------------------------
    // Prestador <-> Pedido matching (business rule)
    // -------------------------
    function prestadorData() {
      return signedIn()
        ? get(/databases/$(database)/documents/prestadores/$(uid())).data
        : null;
    }

    function prestadorMatchesPedido(pedidoData) {
      let p = prestadorData();
      let servicos = (p is map && p.keys().hasAny(['servicos']) && p['servicos'] is list)
        ? p['servicos']
        : [];
      let servicosNomes = (p is map && p.keys().hasAny(['servicosNomes']) && p['servicosNomes'] is list)
        ? p['servicosNomes']
        : [];

      let servicoId = (pedidoData is map && pedidoData.keys().hasAny(['servicoId']))
        ? pedidoData['servicoId']
        : null;

      // Prefer "servicoNome" and fallback to legacy "categoria".
      let categoria = (pedidoData is map && pedidoData.keys().hasAny(['servicoNome']) && pedidoData['servicoNome'] != null)
        ? pedidoData['servicoNome']
        : ((pedidoData is map && pedidoData.keys().hasAny(['categoria'])) ? pedidoData['categoria'] : null);

      return (servicoId is string && servicos.hasAny([servicoId]))
        || (categoria is string && servicosNomes.hasAny([categoria]));
    }

    function pedidoEstado(data) {
      return !(data is map)
        ? null
        : (data.keys().hasAny(['status'])
          ? data['status']
          : (data.keys().hasAny(['estado']) ? data['estado'] : null));
    }

    function isValidPedidoEstadoValue(value) {
      return value is string
        && value in [
          'criado',
          'aguarda_resposta_prestador',
          'aguarda_resposta_cliente',
          'aceito',
          'em_andamento',
          'aguarda_confirmacao_valor',
          'concluido',
          'cancelado'
        ];
    }

    function hasValidPedidoEstado(data) {
      return data is map
        && data.keys().hasAny(['status', 'estado'])
        && (!data.keys().hasAll(['status', 'estado']) ||
          data['status'] == data['estado'])
        && (!data.keys().hasAny(['status']) ||
          isValidPedidoEstadoValue(data['status']))
        && (!data.keys().hasAny(['estado']) ||
          isValidPedidoEstadoValue(data['estado']));
    }

    // Pedido â€œabertoâ€ = visÃ­vel para prestadores na lista
    function pedidoAberto(data) {
      return data is map
        && pedidoEstado(data) == 'criado'
        && (!data.keys().hasAny(['prestadorId']) ||
          data['prestadorId'] == null);
    }

    function immutableField(field) {
      return !resource.data.keys().hasAny([field]) ||
        request.resource.data[field] == resource.data[field];
    }

    function fieldValueOrNull(data, field) {
      return data is map && data.keys().hasAny([field])
        ? data[field]
        : null;
    }

    function isPedidoClienteActor() {
      return signedIn() && clienteIdFromData(resource.data) == uid();
    }

    function isPedidoPrestadorActorForUpdate() {
      let currentPrestadorId = fieldValueOrNull(resource.data, 'prestadorId');
      let nextPrestadorId = fieldValueOrNull(request.resource.data, 'prestadorId');
      return signedIn()
        && (currentPrestadorId == uid() ||
          (currentPrestadorId == null && nextPrestadorId == uid()));
    }

    function isAllowedClientePedidoTransition(from, to) {
      return (from == 'criado' &&
          (to == 'aguarda_resposta_prestador' || to == 'cancelado'))
        || (from == 'aguarda_resposta_prestador' && to == 'cancelado')
        || (from == 'aguarda_resposta_cliente' &&
          (to == 'aceito' || to == 'criado' || to == 'cancelado'))
        || (from == 'aceito' && to == 'cancelado')
        || (from == 'em_andamento' && to == 'cancelado')
        || (from == 'aguarda_confirmacao_valor' &&
          (to == 'concluido' || to == 'em_andamento' || to == 'cancelado'));
    }

    function isAllowedPrestadorPedidoTransition(from, to) {
      return (from == 'criado' &&
          (to == 'aceito' || to == 'aguarda_resposta_cliente'))
        || (from == 'aguarda_resposta_prestador' &&
          (to == 'aceito' || to == 'criado'))
        || (from == 'aguarda_resposta_cliente' && to == 'criado')
        || (from == 'aceito' &&
          (to == 'em_andamento' || to == 'aguarda_resposta_cliente' ||
            to == 'criado'))
        || (from == 'em_andamento' &&
          (to == 'aguarda_confirmacao_valor' || to == 'cancelado'))
        || (from == 'aguarda_confirmacao_valor' && to == 'cancelado');
    }

    function validPedidoStateTransition() {
      let currentEstado = pedidoEstado(resource.data);
      let nextEstado = pedidoEstado(request.resource.data);
      return currentEstado == nextEstado
        || (isPedidoClienteActor() &&
          isAllowedClientePedidoTransition(currentEstado, nextEstado))
        || (isPedidoPrestadorActorForUpdate() &&
          isAllowedPrestadorPedidoTransition(currentEstado, nextEstado));
    }

    function validPrestadorIdTransition() {
      let currentPrestadorId = fieldValueOrNull(resource.data, 'prestadorId');
      let nextPrestadorId = fieldValueOrNull(request.resource.data, 'prestadorId');
      let currentEstado = pedidoEstado(resource.data);
      let nextEstado = pedidoEstado(request.resource.data);
      return currentPrestadorId == nextPrestadorId
        || (
          currentPrestadorId == null &&
          nextPrestadorId == uid() &&
          isAllowedPrestadorPedidoTransition(currentEstado, nextEstado)
        )
        || (
          currentPrestadorId == null &&
          isPedidoClienteActor() &&
          currentEstado == 'criado' &&
          nextEstado == 'aguarda_resposta_prestador' &&
          nextPrestadorId is string
        )
        || (
          currentPrestadorId != null &&
          nextPrestadorId == null &&
          (
            (
              isPedidoClienteActor() &&
              currentEstado == 'aguarda_resposta_cliente' &&
              nextEstado == 'criado'
            ) ||
            (
              currentPrestadorId == uid() &&
              nextEstado == 'criado' &&
              isAllowedPrestadorPedidoTransition(currentEstado, nextEstado)
            )
          )
        );
    }

    function fieldUnchanged(field) {
      return fieldValueOrNull(request.resource.data, field) ==
        fieldValueOrNull(resource.data, field);
    }

    function finalPricingFieldsUnchanged() {
      return fieldUnchanged('precoFinal')
        && fieldUnchanged('preco')
        && fieldUnchanged('commissionPlatform')
        && fieldUnchanged('earningsProvider')
        && fieldUnchanged('earningsTotal');
    }

    function finalProposalFieldsUnchanged() {
      return fieldUnchanged('precoPropostoPrestador')
        && fieldUnchanged('statusConfirmacaoValor');
    }

    function fieldNullOrMissing(data, field) {
      return !(data is map) || !data.keys().hasAny([field]) || data[field] == null;
    }

    function numberWithin(actual, expected) {
      return actual is number
        && expected is number
        && actual >= expected - 0.01
        && actual <= expected + 0.01;
    }

    function clearsFinalPricingFields() {
      return fieldNullOrMissing(request.resource.data, 'precoFinal')
        && fieldNullOrMissing(request.resource.data, 'preco')
        && fieldNullOrMissing(request.resource.data, 'commissionPlatform')
        && fieldNullOrMissing(request.resource.data, 'earningsProvider')
        && fieldNullOrMissing(request.resource.data, 'earningsTotal');
    }

    function validFinalPricingConfirmation() {
      let finalPrice = fieldValueOrNull(request.resource.data, 'precoFinal');
      let proposedPrice = fieldValueOrNull(resource.data, 'precoPropostoPrestador');
      let commission = fieldValueOrNull(request.resource.data, 'commissionPlatform');
      let providerEarnings = fieldValueOrNull(request.resource.data, 'earningsProvider');
      let total = fieldValueOrNull(request.resource.data, 'earningsTotal');
      return isPedidoClienteActor()
        && pedidoEstado(resource.data) == 'aguarda_confirmacao_valor'
        && pedidoEstado(request.resource.data) == 'concluido'
        && request.resource.data['statusConfirmacaoValor'] == 'confirmado_cliente'
        && request.resource.data.keys().hasAll([
          'precoFinal',
          'preco',
          'commissionPlatform',
          'earningsProvider',
          'earningsTotal'
        ])
        && numberWithin(finalPrice, proposedPrice)
        && numberWithin(fieldValueOrNull(request.resource.data, 'preco'), finalPrice)
        && numberWithin(total, finalPrice)
        && numberWithin(commission, finalPrice * 0.15)
        && numberWithin(providerEarnings, finalPrice * 0.85);
    }

    function validFinalPricingUpdate() {
      let nextEstado = pedidoEstado(request.resource.data);
      return finalPricingFieldsUnchanged()
        ? true
        : (clearsFinalPricingFields() &&
          (
            nextEstado == 'criado' ||
            nextEstado == 'aguarda_resposta_prestador' ||
            nextEstado == 'aguarda_resposta_cliente'
          ));
    }

    function validFinalProposalUpdate() {
      let currentEstado = pedidoEstado(resource.data);
      let nextEstado = pedidoEstado(request.resource.data);
      return finalProposalFieldsUnchanged()
        ? true
        : ((
          isPedidoPrestadorActorForUpdate()
          && currentEstado == 'em_andamento'
          && nextEstado == 'aguarda_confirmacao_valor'
          && fieldValueOrNull(request.resource.data, 'precoPropostoPrestador') is number
          && fieldValueOrNull(request.resource.data, 'precoPropostoPrestador') > 0
          && request.resource.data['statusConfirmacaoValor'] == 'pendente_cliente'
        )
        || (
          isPedidoClienteActor()
          && currentEstado == 'aguarda_confirmacao_valor'
          && nextEstado == 'concluido'
          && request.resource.data['statusConfirmacaoValor'] == 'confirmado_cliente'
        )
        || (
          isPedidoClienteActor()
          && currentEstado == 'aguarda_confirmacao_valor'
          && nextEstado == 'em_andamento'
          && request.resource.data['statusConfirmacaoValor'] == 'rejeitado_cliente'
        )
        || (
          fieldNullOrMissing(request.resource.data, 'precoPropostoPrestador')
          && (
            !request.resource.data.keys().hasAny(['statusConfirmacaoValor']) ||
            request.resource.data['statusConfirmacaoValor'] == 'nenhum'
          )
          && (
            nextEstado == 'criado' ||
            nextEstado == 'aguarda_resposta_prestador' ||
            nextEstado == 'aguarda_resposta_cliente'
          )
        ));
    }

    function validPedidoEconomicUpdate() {
      return (
          pedidoEstado(resource.data) == 'aguarda_confirmacao_valor' &&
          pedidoEstado(request.resource.data) == 'concluido'
        )
        ? validFinalPricingConfirmation()
        : (validFinalPricingUpdate() && validFinalProposalUpdate());
    }

    function immutablePedidoIdentity() {
      return clienteIdFromData(request.resource.data) == clienteIdFromData(resource.data)
        && fieldValueOrNull(request.resource.data, 'clientId') ==
          fieldValueOrNull(resource.data, 'clientId')
        && fieldValueOrNull(request.resource.data, 'createdAt') ==
          fieldValueOrNull(resource.data, 'createdAt');
    }

    function validPedidoOpenAccept() {
      return isPrestador()
        && pedidoAberto(resource.data)
        && prestadorMatchesPedido(resource.data)
        && hasValidPedidoEstado(request.resource.data)
        && pedidoEstado(request.resource.data) == 'aceito'
        && fieldValueOrNull(request.resource.data, 'prestadorId') == uid()
        && immutablePedidoIdentity();
    }

    function validPedidoClientManualInvite() {
      return isPedidoClienteActor()
        && pedidoEstado(resource.data) == 'criado'
        && pedidoEstado(request.resource.data) == 'aguarda_resposta_prestador'
        && fieldValueOrNull(resource.data, 'prestadorId') == null
        && fieldValueOrNull(request.resource.data, 'prestadorId') is string
        && immutablePedidoIdentity();
    }

    function validPedidoProviderQuoteProposal() {
      let minValue = fieldValueOrNull(request.resource.data, 'valorMinEstimadoPrestador');
      let maxValue = fieldValueOrNull(request.resource.data, 'valorMaxEstimadoPrestador');
      return isPedidoPrestadorActorForUpdate()
        && prestadorMatchesPedido(resource.data)
        && hasValidPedidoEstado(request.resource.data)
        && isAllowedPrestadorPedidoTransition(
          pedidoEstado(resource.data),
          pedidoEstado(request.resource.data)
        )
        && pedidoEstado(request.resource.data) == 'aguarda_resposta_cliente'
        && fieldValueOrNull(request.resource.data, 'prestadorId') == uid()
        && minValue is number
        && maxValue is number
        && minValue > 0
        && maxValue >= minValue
        && request.resource.data['statusProposta'] == 'pendente_cliente'
        && request.resource.data['statusConfirmacaoValor'] == 'nenhum'
        && fieldNullOrMissing(request.resource.data, 'precoPropostoPrestador')
        && clearsFinalPricingFields()
        && immutablePedidoIdentity();
    }

    function validPedidoProviderFinalProposal() {
      let proposedPrice = fieldValueOrNull(request.resource.data, 'precoPropostoPrestador');
      return isPedidoPrestadorActorForUpdate()
        && hasValidPedidoEstado(request.resource.data)
        && pedidoEstado(resource.data) == 'em_andamento'
        && pedidoEstado(request.resource.data) == 'aguarda_confirmacao_valor'
        && proposedPrice is number
        && proposedPrice > 0
        && request.resource.data['statusConfirmacaoValor'] == 'pendente_cliente'
        && finalPricingFieldsUnchanged()
        && immutablePedidoIdentity();
    }

    function validPedidoProviderStartService() {
      return isPedidoPrestadorActorForUpdate()
        && hasValidPedidoEstado(request.resource.data)
        && pedidoEstado(resource.data) == 'aceito'
        && pedidoEstado(request.resource.data) == 'em_andamento'
        && finalPricingFieldsUnchanged()
        && finalProposalFieldsUnchanged()
        && immutablePedidoIdentity();
    }

    function validPedidoClientFinalConfirmation() {
      return validFinalPricingConfirmation()
        && immutablePedidoIdentity();
    }

    function validPedidoGenericUpdate() {
      return (isPedidoParticipantByData(resource.data)
        || (isPrestador() && pedidoAberto(resource.data) && prestadorMatchesPedido(resource.data)))
        && validPedidoStateTransition()
        && validPrestadorIdTransition()
        && validPedidoEconomicUpdate()
        && immutablePedidoIdentity();
    }

    function validPedidoUpdate() {
      let currentEstado = pedidoEstado(resource.data);
      let nextEstado = pedidoEstado(request.resource.data);
      return !hasValidPedidoEstado(request.resource.data)
        ? false
        : (
          currentEstado == 'criado' && nextEstado == 'aceito'
            ? validPedidoOpenAccept()
            : (
              currentEstado == 'criado' && nextEstado == 'aguarda_resposta_prestador'
                ? validPedidoClientManualInvite()
                : (
                  nextEstado == 'aguarda_resposta_cliente'
                    ? validPedidoProviderQuoteProposal()
                    : (
                      currentEstado == 'em_andamento' && nextEstado == 'aguarda_confirmacao_valor'
                        ? validPedidoProviderFinalProposal()
                        : (
                          currentEstado == 'aceito' && nextEstado == 'em_andamento'
                            ? validPedidoProviderStartService()
                            : (
                              currentEstado == 'aguarda_confirmacao_valor' && nextEstado == 'concluido'
                                ? validPedidoClientFinalConfirmation()
                                : validPedidoGenericUpdate()
                            )
                        )
                    )
                )
            )
        );
    }

    // -------------------------
    // Chat helpers
    // -------------------------
    function isChatParticipantByData(chatData) {
      return signedIn() && chatData is map
        ? (
          clienteIdFromData(chatData) == uid() ||
          (chatData.keys().hasAny(['prestadorId']) &&
            chatData['prestadorId'] == uid())
        )
        : false;
    }

    function chatSnap(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }

    // Ãštil para subcoleÃ§Ãµes (messages)
    function isChatParticipant(chatId) {
      let c = chatSnap(chatId).data;
      return isChatParticipantByData(c);
    }

    function hasTextField(data) {
      return data is map
        && (
          (data.keys().hasAny(['text']) && data['text'] is string) ||
          (data.keys().hasAny(['texto']) && data['texto'] is string) ||
          (data.keys().hasAny(['message']) && data['message'] is string) ||
          (data.keys().hasAny(['conteudo']) && data['conteudo'] is string)
        );
    }

    function hasMediaField(data) {
      return data is map
        && (
          (data.keys().hasAny(['mediaUrl']) && data['mediaUrl'] is string) ||
          (data.keys().hasAny(['fileUrl']) && data['fileUrl'] is string) ||
          (data.keys().hasAny(['url']) && data['url'] is string)
        );
    }

    function hasValidMessageType(data) {
      return data is map
        && (
          !data.keys().hasAny(['type']) ||
          data['type'] in ['text', 'image', 'audio', 'file', 'location', 'call', 'sticker', 'gif']
        );
    }

    // -------------------------
    // Call helpers
    // -------------------------
    function callSnap(callId) {
      return get(/databases/$(database)/documents/calls/$(callId));
    }

    function isCallParticipantByData(callData) {
      return signedIn() && callData is map
        ? (
          (callData.keys().hasAny(['callerId']) && callData['callerId'] == uid()) ||
          (callData.keys().hasAny(['calleeId']) && callData['calleeId'] == uid())
        )
        : false;
    }

    function isCallParticipantById(callId) {
      let c = callSnap(callId).data;
      return isCallParticipantByData(c);
    }

    // -------------------------
    // USERS
    // -------------------------
    match /users/{userId} {
      allow read: if signedIn() || isAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin() || devMode();

      match /fcmTokens/{tokenId} {
        allow read, write: if isSelf(userId) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow read, update: if isSelf(userId) || isAdmin();
        allow create: if false; // sÃ³ backend/admin
        allow delete: if isAdmin() || devMode();
      }
    }

    match /users/{userId}/favorites/{prestadorId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    // -------------------------
    // PRESTADORES
    // -------------------------
    match /prestadores/{prestadorId} {
      allow read: if true; // perfis precisam ser visíveis
      allow create: if isSelf(prestadorId) || isAdmin();
      
      // Owner can update own profile, but cannot self-edit rating aggregates.
      // Rating aggregates are allowed only for other signed-in users (or backend/admin).
      allow update: if isAdmin()
        || (
          isSelf(prestadorId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .difference(['ratingCount', 'ratingSum', 'ratingAvg'].toSet()).size()
            == request.resource.data.diff(resource.data).affectedKeys().size()
        )
        || (
          signedIn()
          && uid() != prestadorId
          && request.resource.data.diff(resource.data).affectedKeys()
             .difference(['ratingCount', 'ratingSum', 'ratingAvg', 'updatedAt'].toSet()).size() == 0
        );

      allow delete: if isAdmin() || devMode();
    }

    // -------------------------
    // AVALIACOES
    // -------------------------
    match /avaliacoes/{avaliacaoId} {
      allow read: if isPedidoParticipantById(resource.data['pedidoId'])
        || isAdmin();

      allow create: if signedIn()
        && request.resource.data['pedidoId'] is string
        && clienteIdFromData(request.resource.data) == uid()
        && request.resource.data['prestadorId'] is string
        && request.resource.data['estrelas'] is int
        && request.resource.data['estrelas'] >= 1
        && request.resource.data['estrelas'] <= 5
        && isPedidoParticipantById(request.resource.data['pedidoId'])
        && (
          pedidoSnap(request.resource.data['pedidoId']).data['estado'] == 'concluido' ||
          pedidoSnap(request.resource.data['pedidoId']).data['status'] == 'concluido'
        )
        && pedidoSnap(request.resource.data['pedidoId']).data['prestadorId']
          == request.resource.data['prestadorId'];

      allow update, delete: if isAdmin() || devMode();
    }

    // -------------------------
    // SERVICOS (catÃ¡logo)
    // -------------------------
    match /servicos/{servicoId} {
      allow read: if true;
      allow create, update, delete: if devMode() || isAdmin();
    }

    // -------------------------
    // STORIES
    // -------------------------
    match /stories/{storyId} {
      allow read: if true;
      allow create: if devMode() || isAdmin()
        || (signedIn() && request.resource.data['prestadorId'] == uid());
      allow update, delete: if isAdmin() || devMode()
        || (signedIn() && resource.data['prestadorId'] == uid());
    }

    // -------------------------
    // PEDIDOS
    // -------------------------
    match /pedidos/{pedidoId} {

      // Criar pedido: tem de ser o cliente
      allow create: if signedIn()
        && clienteIdFromData(request.resource.data) == uid()
        && hasValidPedidoEstado(request.resource.data);

      // Ler (get + list):
      // - cliente e prestador (quando atribuÃ­do)
      // - prestadores podem ler pedidos abertos (Pedidos perto de ti)
      allow read: if devMode()
        ? true
        : (isPedidoParticipantByData(resource.data)
          || (isPrestador() && pedidoAberto(resource.data))
          || isAdmin());

      // Atualizar:
      // - cliente/prestador participantes
      // - prestador pode aceitar/agir num pedido aberto (SÓ se fizer match com o serviço)
      allow update: if validPedidoUpdate();

      allow delete: if isAdmin() || devMode();
    }

    // -------------------------
    // CHATS (chatId == pedidoId)
    // -------------------------
    match /chats/{chatId} {

      // âœ… GET (doc especÃ­fico): participante via pedido OU via chat
      allow get: if (resource != null && resource.data is map && isChatParticipantByData(resource.data))
                  || isPedidoParticipantById(chatId);

      // âœ… LIST (queries): usa sÃ³ os campos do prÃ³prio chat
      allow list: if resource != null && resource.data is map && isChatParticipantByData(resource.data);

      // Criar meta do chat
      allow create: if isPedidoParticipantById(chatId)
        && request.resource.data['pedidoId'] == chatId;

      // Update: participante via pedido ou via chat
      allow update: if (resource != null && resource.data is map && isChatParticipantByData(resource.data))
                    || isPedidoParticipantById(chatId);

      allow delete: if isAdmin() || devMode();

      match /messages/{messageId} {
        allow get, list: if isPedidoParticipantById(chatId) || isChatParticipant(chatId);

        // Criar mensagem: participante e senderId tem de ser o prÃ³prio
        allow create: if (isPedidoParticipantById(chatId) || isChatParticipant(chatId))
          && request.resource.data['senderId'] == uid()
          && (
            hasTextField(request.resource.data) ||
            (hasMediaField(request.resource.data) && hasValidMessageType(request.resource.data))
          );

        // delivered/seen/etc.
        allow update: if isPedidoParticipantById(chatId) || isChatParticipant(chatId);

        allow delete: if isAdmin() || devMode();
      }

      match /typing/{userId} {
        allow read: if isChatParticipant(chatId);
        allow create, update, delete: if isChatParticipant(chatId) && isSelf(userId);
      }
    }

    // -------------------------
    // CALLS (audio/video)
    // -------------------------
    match /calls/{callId} {
      allow create: if signedIn()
        && request.resource.data['callerId'] == uid()
        && request.resource.data['calleeId'] is string;

      allow get: if isCallParticipantByData(resource.data);
      allow list: if resource != null
        && resource.data is map
        && isCallParticipantByData(resource.data);
      allow update: if isCallParticipantByData(resource.data);
      allow delete: if isAdmin() || devMode();

      match /offerCandidates/{candidateId} {
        allow read, write: if isCallParticipantById(callId);
      }

      match /answerCandidates/{candidateId} {
        allow read, write: if isCallParticipantById(callId);
      }
    }

    // -------------------------
    // SUPPORT TICKETS
    // -------------------------
    match /support_tickets/{ticketId} {
      allow create: if signedIn()
        && request.resource.data['uid'] == uid();
      allow read, update, delete: if isAdmin() || devMode();
    }

    // -------------------------
    // PAYMENTS (admin/backoffice read-only)
    // -------------------------
    match /payments/{paymentId} {
      allow read: if isAdmin() || devMode();
      allow create, update, delete: if false; // only backend/admin SDK
    }

    // -------------------------
    // PAYMENT LEDGER (immutable)
    // -------------------------
    match /payment_ledger/{entryId} {
      allow read: if isAdmin() || devMode();
      allow create, update, delete: if false; // only backend/admin SDK
    }

    // -------------------------
    // SUBSCRIPTIONS (owner + admin read-only)
    // -------------------------
    match /subscriptions/{subUid} {
      allow read: if (signedIn() && uid() == subUid) || isAdmin() || devMode();
      allow create, update, delete: if false; // only backend/admin SDK
    }

    // -------------------------
    // REMINDER LOGS (scheduler dedup)
    // -------------------------
    match /scheduled_reminder_logs/{logId} {
      allow read: if isAdmin() || devMode();
      allow create, update, delete: if false; // only backend/admin SDK
    }

    // -------------------------
    // Default deny
    // -------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
